RewriteEngine On
RewriteBase /ads/

# Handle directory without trailing slash
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*[^/])$ $1/ [L,R=301]

# Rewrite URLs to PHP files
RewriteRule ^pages/about$ pages/about/index.php [L]
RewriteRule ^pages/about/$ pages/about/index.php [L]
RewriteRule ^pages/services$ pages/services/index.php [L]
RewriteRule ^pages/services/$ pages/services/index.php [L]
RewriteRule ^pages/projects$ pages/projects/index.php [L]
RewriteRule ^pages/projects/$ pages/projects/index.php [L]
RewriteRule ^pages/blog$ pages/blog/index.php [L]
RewriteRule ^pages/blog/$ pages/blog/index.php [L]
RewriteRule ^pages/testimonials$ pages/testimonials/index.php [L]
RewriteRule ^pages/testimonials/$ pages/testimonials/index.php [L]


<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Chặn truy cập trực tiếp vào thư mục hình ảnh
    RewriteCond %{HTTP_REFERER} !^http://(www\.)?localhost [NC]
    RewriteCond %{HTTP_REFERER} !^http://(www\.)?your-domain.com [NC]
    RewriteRule \.(jpg|jpeg|png|gif)$ - [F,NC]

    # Thêm tiêu đề bảo mật
    <FilesMatch "\.(jpg|jpeg|png|gif)$">
        Header set X-Content-Type-Options "nosniff"
        Header set X-Frame-Options "SAMEORIGIN"
        Header set Content-Security-Policy "img-src 'self'"
    </FilesMatch>
</IfModule>


